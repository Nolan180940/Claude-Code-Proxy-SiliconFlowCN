@echo off
chcp 65001 >nul
title Claude Code - Silicon Flow

echo ========================================
echo   Claude Code - Silicon Flow CN
echo ========================================
echo.

REM Set environment variables (replace with your SiliconFlow API Key)
set SILICONFLOW_API_KEY=sk-your-siliconflow-api-key-here
set ANTHROPIC_BASE_URL=http://127.0.0.1:8787
set ANTHROPIC_API_KEY=sk-siliconflow-proxy

REM Kill old proxy process
echo [0/2] Killing old proxy process...
taskkill /f /im node.exe /fi "WINDOWTITLE eq Claude-Proxy*" >nul 2>&1

REM Start proxy server (background, minimized)
echo [1/2] Starting API proxy server...
start "Claude-Proxy" /MIN cmd /c "set SILICONFLOW_API_KEY=sk-your-siliconflow-api-key-here && node server.js"

REM Wait for proxy to start
echo Waiting for proxy to start...
timeout /t 3 /nobreak >nul

REM Start Claude Code (--bare forces API Key mode, skips OAuth login)
echo [2/2] Starting Claude Code...
echo.
claude --bare

echo.
echo Claude Code exited.
echo Close the proxy window to fully exit.
pause