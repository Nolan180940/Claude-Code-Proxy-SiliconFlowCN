# ========================================
#  Claude Code - Silicon Flow (PowerShell)
#  Usage: Start start-proxy.bat first, then run this script
# ========================================

Write-Host "========================================" -ForegroundColor Cyan
Write-Host "  Claude Code - Silicon Flow CN" -ForegroundColor Cyan
Write-Host "========================================" -ForegroundColor Cyan
Write-Host ""

# Set environment variables (replace with your SiliconFlow API Key)
$env:SILICONFLOW_API_KEY = "sk-your-siliconflow-api-key-here"
$env:ANTHROPIC_BASE_URL = "http://127.0.0.1:8787"
$env:ANTHROPIC_API_KEY = "sk-siliconflow-proxy"

Write-Host "ANTHROPIC_BASE_URL = $env:ANTHROPIC_BASE_URL" -ForegroundColor Green
Write-Host "Proxy check: http://127.0.0.1:8787" -ForegroundColor Green
Write-Host ""

# Quick check if proxy is online
try {
    $response = Invoke-WebRequest -Uri "http://127.0.0.1:8787" -TimeoutSec 2 -UseBasicParsing
    Write-Host "[OK] Proxy is online!" -ForegroundColor Green
} catch {
    Write-Host "[WARN] Proxy not responding on port 8787!" -ForegroundColor Yellow
    Write-Host "       Make sure start-proxy.bat is running first." -ForegroundColor Yellow
    Write-Host ""
}

Write-Host "Starting Claude Code..." -ForegroundColor Cyan
Write-Host ""

# Start Claude Code
claude --bare

Write-Host ""
Write-Host "Claude Code exited." -ForegroundColor Gray
