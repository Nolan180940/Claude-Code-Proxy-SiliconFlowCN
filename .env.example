# SiliconFlow API Key（必填）
# 在 https://cloud.siliconflow.cn 注册获取
SILICONFLOW_API_KEY=sk-your-api-key-here

# 模型映射（可选，默认使用 DeepSeek-V4-Pro）
# SILICONFLOW_DEFAULT_MODEL=deepseek-ai/DeepSeek-V4-Pro
# SILICONFLOW_SONNET_MODEL=deepseek-ai/DeepSeek-V4-Pro
# SILICONFLOW_OPUS_MODEL=deepseek-ai/DeepSeek-V4-Pro
# SILICONFLOW_HAIKU_MODEL=deepseek-ai/DeepSeek-V4-Pro

# 代理端口（可选，默认 8787）
# PORT=8787